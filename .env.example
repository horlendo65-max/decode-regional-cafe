# Copy this file to .env.local and fill in real values.
# See workshop/00-prep/README.md for how to get each of these.

# --- AI provider (Module 02) ---
# Pick ONE provider and fill in its key only — you don't need all four.
# See workshop/FREE-AI-MODELS.md for signup links and current model names.
AI_PROVIDER=groq

# Groq (fast, recommended default)
GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b

# Google Gemini (AI Studio) — fallback if Groq is blocked/rate-limited
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# OpenRouter — many free models behind one key
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Cerebras — very fast inference, smaller free catalog
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama-3.3-70b

# --- Daraja / M-Pesa sandbox (Module 03) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=

# Public URL of this deployment, no trailing slash.
# Locally this can stay as http://localhost:3000 for everything except
# the Daraja callback, which needs a real HTTPS URL (use your Vercel URL
# once deployed in Module 01).
NEXT_PUBLIC_APP_URL=http://localhost:3000
